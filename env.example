# Supabase (DB only — Clerk handles auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # only used by cron/admin (service.ts)

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/map
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Mapbox (server-only — no NEXT_PUBLIC_ prefix, never exposed in client JS bundle)
MAPBOX_TOKEN=your-mapbox-token

# Cron (protege /api/cron/scrape de llamadas no autorizadas)
CRON_SECRET=un-string-random-seguro
